---
interface Props {
  lang?: 'en' | 'zh-cn';
}
const { lang = 'en' } = Astro.props;
---

<release-downloads data-lang={lang}>
  <p class="rd-loading">{lang === 'zh-cn' ? '正在获取最新版本…' : 'Loading latest release…'}</p>
</release-downloads>

<script>
class ReleaseDownloads extends HTMLElement {
  async connectedCallback() {
    const zh = this.dataset.lang === 'zh-cn';
    try {
      const res = await fetch(
        'https://api.github.com/repos/xifan2333/fcitx5-vinput/releases/latest',
      );
      if (!res.ok) throw new Error();
      const release = await res.json();
      this.render(release, zh);
    } catch {
      const url = 'https://github.com/xifan2333/fcitx5-vinput/releases';
      this.innerHTML = zh
        ? `<p>加载失败，请<a href="${url}">前往 GitHub Releases</a></p>`
        : `<p>Failed to load. <a href="${url}">View releases on GitHub</a></p>`;
    }
  }

  render(
    release: { tag_name: string; assets: { name: string; browser_download_url: string }[] },
    zh: boolean,
  ) {
    const assets = release.assets
      .filter((a) => !a.name.includes('debug'))
      .map((a) => ({ name: a.name, url: a.browser_download_url, label: labelFor(a.name, zh) }))
      .filter((a): a is { name: string; url: string; label: string } => a.label != null);

    const order = ['Arch', 'Ubuntu', 'Debian', 'Fedora', 'RPM', 'Flatpak', 'Generic', '通用', 'Source', '源'];
    assets.sort((a, b) => {
      const ai = order.findIndex((o) => a.label.startsWith(o));
      const bi = order.findIndex((o) => b.label.startsWith(o));
      return (ai < 0 ? 99 : ai) - (bi < 0 ? 99 : bi);
    });

    const tag = release.tag_name;
    this.innerHTML = `
      <p class="rd-version"><strong>${zh ? '最新版本' : 'Latest release'}：${tag}</strong></p>
      <div class="rd-table-wrap">
        <table>
          <thead><tr><th>${zh ? '平台' : 'Platform'}</th><th>${zh ? '下载' : 'Download'}</th></tr></thead>
          <tbody>${assets.map((a) => `<tr><td>${a.label}</td><td><a href="${a.url}"><code>${a.name}</code></a></td></tr>`).join('')}</tbody>
        </table>
      </div>
    `;
  }
}

function labelFor(name: string, zh: boolean): string | null {
  if (name.endsWith('.pkg.tar.zst')) return 'Arch Linux';
  if (/ubuntu.*\.deb$/.test(name)) return 'Ubuntu 24.04';
  if (/debian.*\.deb$/.test(name)) return 'Debian 12';
  if (/\.fc\d+\..*\.rpm$/.test(name)) return 'Fedora';
  if (/\.rpm$/.test(name)) return zh ? 'RPM（通用）' : 'RPM (generic)';
  if (name.endsWith('.flatpak')) return 'Flatpak';
  if (/bundled\.tar\.gz$/.test(name)) return zh ? '通用 Linux（捆绑包）' : 'Generic Linux (bundled)';
  if (name.endsWith('.tar.gz')) return zh ? '源代码' : 'Source code';
  return null;
}

customElements.define('release-downloads', ReleaseDownloads);
</script>

<style>
  release-downloads {
    display: block;
  }

  .rd-loading {
    color: var(--sl-color-gray-3);
    font-style: italic;
  }
</style>
